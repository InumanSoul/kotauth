root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 120
# Wildcard imports are intentional in DSL-heavy adapters (Exposed ORM, Ktor).
# Banning them would make persistence adapters unnecessarily verbose.
ktlint_standard_no-wildcard-imports = disabled

# kotlinx.html DSL view files — deeply nested lambdas cause non-converging
# formatter loops between indent and wrapping rules. Disable ktlint entirely.
[*View.kt]
ktlint = disabled

[*Views.kt]
ktlint = disabled

[*.{yml,yaml}]
indent_size = 2

[*.{json,js,ts,tsx}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
