# ─── Kotauth — environment template ──────────────────────────────────────────
# Copy this file to .env and fill in the values before running.
#
#   cp .env.example .env
#
# .env is gitignored and never committed. This file IS committed.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Kotauth ──────────────────────────────────────────────────────────────────

# Public base URL. Used as the OIDC issuer, in discovery documents, redirect URI
# validation, and password-reset / verification email links.
# No trailing slash. Must be https:// when KAUTH_ENV=production.
KAUTH_BASE_URL=http://localhost:8080

# Runtime mode. Set to "production" to enforce HTTPS and strict startup checks.
# Default: development
KAUTH_ENV=development

# 32+ char hex string for AES-256-GCM encryption and session signing.
# Without this: SMTP config unavailable, sessions lost on container restart.
# Generate one: openssl rand -hex 32
KAUTH_SECRET_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────

# Database name created inside the postgres container.
DB_NAME=kotauth_db

# PostgreSQL credentials — used by both the db service and the app service.
# Change these before going to production.
DB_USER=kotauth
DB_PASSWORD=changeme
