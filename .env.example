# ─── Kotauth — environment template ──────────────────────────────────────────
# Copy this file to .env and fill in the values before running.
#
#   cp .env.example .env
#
# .env is gitignored and never committed. This file IS committed.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Kotauth ──────────────────────────────────────────────────────────────────

# Public base URL. Used as the OIDC issuer, in discovery documents, redirect URI
# validation, and password-reset / verification email links.
# No trailing slash. Must be https:// when KAUTH_ENV=production.
KAUTH_BASE_URL=http://localhost:8080

# Runtime mode. Set to "production" to enforce HTTPS and strict startup checks.
# Default: development
KAUTH_ENV=development

# REQUIRED — 32+ char string for AES-256-GCM encryption and session signing.
# The server will not start without this key.
# Generate one: openssl rand -hex 32
KAUTH_SECRET_KEY=

# ─── Database — bundled (default) ─────────────────────────────────────────────
# These vars configure the bundled PostgreSQL service and are used to construct
# the JDBC connection URL for the app. Change DB_PASSWORD before going to production.

DB_HOST=db           # Docker service name — change to your host for external DBs
DB_PORT=5432         # Default PostgreSQL port
DB_NAME=kotauth_db
DB_USER=kotauth
DB_PASSWORD=changeme

# ─── Database — connection pool (optional) ─────────────────────────────────
# HikariCP pool sizing. Defaults are suitable for single-instance deployments.
# For multi-instance, ensure total connections across all instances stay within
# PostgreSQL's max_connections (default 100).
#
# DB_POOL_MAX_SIZE=10    # Maximum connections in the pool
# DB_POOL_MIN_IDLE=2     # Minimum idle connections kept open

# ─── Database — external / managed (optional override) ────────────────────────
# Set DB_URL to connect to an external or managed database. When set, DB_URL
# takes full precedence and DB_HOST / DB_PORT / DB_NAME above are ignored.
# Append ?sslmode=require for most managed providers (RDS, Supabase, Neon, etc.)
#
# Use docker/docker-compose.external-db.yml instead of docker-compose.yml
# to skip the bundled PostgreSQL container entirely:
#   docker compose -f docker/docker-compose.external-db.yml up -d
#
# DB_URL=jdbc:postgresql://your-host:5432/kotauth_db?sslmode=require

# ─── Demo mode ────────────────────────────────────────────────────────────────
# Set to "true" to seed realistic demo data on startup (workspaces, users,
# applications, roles, groups). Shows a demo banner on all pages.
# Intended for public showcase deployments. Default: false (disabled).
#
# KAUTH_DEMO_MODE=true

# ─── Docker production stack (docker/docker-compose.prod.yml) ─────────────────
# Only required when using the Caddy TLS overlay.
#
# DOMAIN=auth.yourdomain.com
# ACME_EMAIL=you@yourdomain.com
