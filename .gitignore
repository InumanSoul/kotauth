# Docker
docker-compose.override.yml

# CSS tooling — installed at build time, never committed
# LightningCSS CLI is managed via frontend/package.json.
# Run `./gradlew compileCssAdmin compileCssAuth` (installs deps automatically).
# See docs/FRONTEND_CSS.md → Development Workflow.
frontend/node_modules/

# Compiled CSS — generated at build time, never hand-edited
# Source lives in frontend/css/. Docker and Gradle generate these automatically.
src/main/resources/static/kotauth-admin.css
src/main/resources/static/kotauth-auth.css

# Version metadata — generated at build time by the generateVersionProperties Gradle task
src/main/resources/version.properties

# AI tools
ai-tools/
.claude/
.cursor/

# Internal development tracking — not for public consumption
docs/internal/
