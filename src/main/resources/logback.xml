<configuration>
    <!--
        Structured JSON logging via logstash-logback-encoder.

        Every log line is a single JSON object — ready for Docker log drivers,
        Loki, ELK, Datadog, or any log aggregator that ingests NDJSON.

        MDC fields injected by the CallId + CallLogging plugins in Application.kt:
          - requestId   : UUID per HTTP request (from CallId plugin)
          - tenantSlug  : extracted from /t/{slug}/... route paths

        To pretty-print locally:  docker logs kotauth | jq .
    -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Use ISO-8601 UTC timestamps -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
            <!-- Keep MDC fields at the top level (not nested under "mdc") -->
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <includeMdcKeyName>tenantSlug</includeMdcKeyName>
        </encoder>
    </appender>

    <!-- Suppress Exposed SQL framework debug noise -->
    <logger name="Exposed" level="WARN"/>
    <!-- Suppress HikariCP connection pool chatter -->
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <!-- Keep Flyway migration logs — useful to see which version ran -->
    <logger name="org.flywaydb" level="INFO"/>
    <!-- Netty internals are irrelevant at INFO level -->
    <logger name="io.netty" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
